    {
      "name": "Debug cometvisu-knxd-fcgi",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/src/cometvisu-knxd-fcgi",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
