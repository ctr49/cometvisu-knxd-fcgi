{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake-configure",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-B",
        "build",
        "-DCMAKE_BUILD_TYPE=Debug",
        "-DBUILD_TESTING=ON"
      ],
      "group": "build",
      "problemMatcher": [],
      "detail": "Configure the CMake project (Debug, with tests)"
    },
    {
      "label": "cmake-build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "-j",
        "${nproc}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "dependsOn": [
        "cmake-configure"
      ],
      "detail": "Build the entire project (all targets)"
    },
    {
      "label": "cmake-build-main",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "-j",
        "${nproc}",
        "--target",
        "cometvisu-knxd-fcgi"
      ],
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ],
      "dependsOn": [
        "cmake-configure"
      ],
      "detail": "Build only the main executable"
    },
    {
      "label": "cmake-test",
      "type": "shell",
      "command": "ctest",
      "args": [
        "--test-dir",
        "build",
        "--output-on-failure"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": [],
      "dependsOn": [
        "cmake-build"
      ],
      "detail": "Run all tests via CTest"
    },
    {
      "label": "cmake-test-unit",
      "type": "shell",
      "command": "ctest",
      "args": [
        "--test-dir",
        "build",
        "--output-on-failure",
        "-R",
        "^test_"
      ],
      "group": "test",
      "problemMatcher": [],
      "dependsOn": [
        "cmake-build"
      ],
      "detail": "Run only unit tests (test_*)"
    },
    {
      "label": "cmake-test-specific",
      "type": "shell",
      "command": "ctest",
      "args": [
        "--test-dir",
        "build",
        "--output-on-failure",
        "-R",
        "${input:testName}"
      ],
      "group": "test",
      "problemMatcher": [],
      "dependsOn": [
        "cmake-build"
      ],
      "detail": "Run a specific test by name pattern"
    },
    {
      "label": "cmake-clean",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "--target",
        "clean"
      ],
      "group": "build",
      "problemMatcher": [],
      "detail": "Clean all build artifacts"
    },
    {
      "label": "cmake-rebuild",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build",
        "--clean-first",
        "-j",
        "${nproc}"
      ],
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ],
      "dependsOn": [
        "cmake-configure"
      ],
      "detail": "Clean rebuild of the entire project"
    },
    {
      "label": "cmake-reconfigure",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-B",
        "build",
        "-DCMAKE_BUILD_TYPE=Debug",
        "-DBUILD_TESTING=ON"
      ],
      "group": "build",
      "problemMatcher": [],
      "detail": "Reconfigure from scratch (removes CMakeCache.txt first)"
    },
    // ============================================================
    // knxd background tasks
    // ============================================================
    {
      "label": "knxd-start-ipt",
      "type": "shell",
      "command": "${workspaceFolder}/tools/start-knxd-ipt.sh",
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": "\\[start-knxd\\] knxd ready on (.+)",
            "kind": "file",
            "file": 1,
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[start-knxd\\] Starting knxd with:",
          "endsPattern": "\\[start-knxd\\] knxd ready on .+"
        }
      },
      "detail": "Start knxd with IP Routing (no hardware needed, uses unlikely multicast address)"
    },
    {
      "label": "knxd-stop",
      "type": "shell",
      "command": "pkill knxd 2>/dev/null; echo 'knxd stopped'",
      "problemMatcher": [],
      "detail": "Stop all knxd processes"
    },
    {
      "label": "build-and-start-knxd-ipt",
      "dependsOn": [
        "cmake-build-main",
        "knxd-start-ipt"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "detail": "Build the project, then start knxd with IP Routing (no hardware needed)"
    },
    // ============================================================
    // Run tasks (no debugger — use these to run the app standalone)
    // ============================================================
    {
      "label": "Run against real knxd",
      "type": "shell",
      "command": "${workspaceFolder}/build/src/cometvisu-knxd-fcgi",
      "isBackground": true,
      "dependsOn": [
        "cmake-build-main"
      ],
      "options": {
        "env": {
          "FCGI_SOCKET": ":9000",
          "DEBUG_BACKEND": "1",
          "KNXD_SOCKET": "/run/knx",
          "LONGPOLL_TIMEOUT_SEC": "300"
        }
      },
      "problemMatcher": {
        "pattern": [
          {
            "regexp": "^\\[INFO\\] Direct FCGI socket: (.+)$",
            "kind": "file",
            "file": 1,
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[INFO\\] cometvisu-knxd-fcgi starting",
          "endsPattern": "^\\[INFO\\] Direct FCGI socket:"
        }
      },
      "detail": "Run the FCGI backend against a real knxd instance (no debugger)"
    },
    {
      "label": "Run with local knxd (E2E)",
      "type": "shell",
      "command": "${workspaceFolder}/build/src/cometvisu-knxd-fcgi",
      "isBackground": true,
      "dependsOn": [
        "build-and-start-knxd-ipt"
      ],
      "dependsOrder": "sequence",
      "options": {
        "env": {
          "FCGI_SOCKET": ":9000",
          "DEBUG_BACKEND": "1",
          "KNXD_SOCKET": "/tmp/knxd-ipt",
          "LONGPOLL_TIMEOUT_SEC": "300"
        }
      },
      "problemMatcher": {
        "pattern": [
          {
            "regexp": "^\\[INFO\\] Direct FCGI socket: (.+)$",
            "kind": "file",
            "file": 1,
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[INFO\\] cometvisu-knxd-fcgi starting",
          "endsPattern": "^\\[INFO\\] Direct FCGI socket:"
        }
      },
      "detail": "Run the FCGI backend against a local knxd instance (no debugger, no hardware needed)"
    }
  ],
  "inputs": [
    {
      "id": "testName",
      "type": "promptString",
      "description": "Enter a test name pattern (regex) to run (e.g. test_hex, test_query_string)"
    }
  ]
}